---
const { value, label } = Astro.props;
---
<div class="flex flex-col items-center justify-center border border-zinc-700/60 rounded-lg p-4 aspect-square text-center">
  <span class="font-bold text-xl sm:text-4xl leading-none tracking-tight bg-gradient-to-b from-white to-zinc-400 bg-clip-text text-transparent">{value}</span>
  <span class="text-zinc-500 text-[10px] sm:text-xs mt-2 sm:mt-3 leading-snug">{label}</span>
</div>
